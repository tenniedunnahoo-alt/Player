<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.PremiumVideoPlayer" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryDark">@color/purple_dark</item>
        <item name="colorAccent">@color/purple_accent</item>
        <item name="android:colorBackground">@color/amoled_black</item>
        <item name="android:windowBackground">@color/amoled_black</item>
        <item name="android:statusBarColor">@color/amoled_black</item>
        <item name="android:navigationBarColor">@color/amoled_black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="materialCardViewStyle">@style/Widget.Premium.Card</item>
    </style>

    <style name="Theme.PremiumVideoPlayer.Splash" parent="Theme.PremiumVideoPlayer">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/amoled_black</item>
        <item name="android:navigationBarColor">@color/amoled_black</item>
    </style>

    <style name="Theme.PremiumVideoPlayer.Fullscreen" parent="Theme.PremiumVideoPlayer">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/amoled_black</item>
    </style>

    <style name="Widget.Premium.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">0dp</item>
    </style>

    <style name="Widget.Premium.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/purple_primary</item>
        <item name="android:textColor">@color/amoled_black</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Premium.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/purple_primary</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="PremiumBottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface_dark</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Premium.BottomNav.Indicator</item>
    </style>

    <style name="Widget.Premium.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/purple_primary</item>
    </style>

    <style name="PremiumSeekBar" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressDrawable">@drawable/seekbar_progress</item>
        <item name="android:thumb">@drawable/seekbar_thumb</item>
    </style>
</resources>
